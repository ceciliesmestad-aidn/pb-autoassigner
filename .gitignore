# Secrets — never commit these
config.toml
.env
*.token

# pms_custom.json is intentionally NOT ignored — it is the on-disk store for
# PMs added via the UI. Commit it to keep your PM list across re-clones.

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Data
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/exports/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# macOS
.DS_Store

# Logs
*.log
